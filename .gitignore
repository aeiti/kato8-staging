CLAUDE.md
TASKS.md
.DS_Store
node_modules
dist
dist-ssr
*.local
.vite

# macOS case-insensitive filesystem aliases the lowercase /assets/ and
# capital /Assets/ paths to the same physical dir. Ignore the capital-A
# views so git status doesn't show phantom untracked entries every time
# something writes to /assets/.
public/Assets/
docs/Assets/

# Generated WebP variants under src/assets/games/**/concept/ (produced
# at build time by scripts/generate-image-variants.mjs). Source images
# are committed; variants regenerate from them on every build.
src/assets/games/**/concept/**/*-[0-9]*w.webp

# Copy to `.env.local` for local dev. `.env.local` is gitignored (see
# `*.local` in .gitignore). For production/staging builds these are
# injected as GitHub Actions secrets in the deploy workflows.
#
# Any variable that must be exposed to client JS must start with `VITE_`.
# See https://vitejs.dev/guide/env-and-mode.html

# Newsletter email signup (existing).
VITE_NEWSLETTER_ENDPOINT=

# Universal Serial Blade playtest sign-up. Formspree endpoint of the
# form https://formspree.io/f/xxxxxxxx — configured in the Formspree
# dashboard to notify terryt@katostudios.com.
VITE_USB_PLAYTEST_ENDPOINT=

# Universal Serial Blade Discord community application. Same shape as
# above; separate Formspree form so submissions are attributable.
VITE_USB_DISCORD_ENDPOINT=
